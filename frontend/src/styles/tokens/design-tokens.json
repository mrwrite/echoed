  "font": {
    "family": {
      "body": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
      "display": "Cal Sans, Inter, ui-sans-serif, system-ui, sans-serif",
      "serif": "Georgia, Cambria, Times New Roman, serif"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "2rem",
      "4xl": "2.5rem"
    },
    "lineHeight": {
      "tight": "1.15",
      "heading": "1.25",
      "body": "1.6"
    },
    "weight": {
      "regular": "400",
      "medium": "500",
      "semibold": "650",
      "bold": "750"
    }
  },
  "space": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "layout": {
      "page": "clamp(1rem, 3vw, 2rem)",
      "section": "clamp(1.5rem, 4vw, 4rem)",
      "contentMax": "72rem"
    }
  },
  "radius": {
    "control": {
      "sm": "0.375rem",
      "default": "0.5rem",
      "pill": "999px"
    },
    "card": {
      "default": "0.5rem",
      "large": "0.75rem"
    },
    "dialog": "0.75rem"
  },
  "shadow": {
    "none": "none",
    "raised": "0 12px 28px rgba(16, 32, 51, 0.12)",
    "overlay": "0 24px 64px rgba(16, 32, 51, 0.24)"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "180ms",
      "slow": "260ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "focus": {
    "ring": {
      "color": "#0f766e",
      "width": "2px",
      "offset": "3px",
      "shadow": "0 0 0 4px rgba(15, 118, 110, 0.18)"
    }
  },
  "breakpoint": {
    "mobile": "390px",
    "tablet": "768px",
    "smallDesktop": "1280px",
    "desktop": "1440px"
  }
}
